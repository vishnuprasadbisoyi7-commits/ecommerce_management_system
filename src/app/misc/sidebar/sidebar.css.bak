:host {
  display: block;
  width: 260px;
  flex: 0 0 260px;
  transition: width 0.25s ease, flex-basis 0.25s ease;
}

:host(.collapsed) {
  width: 96px;
  flex-basis: 96px;
}

.sidebar {
  width: 100%;
  background: linear-gradient(160deg, #2f3146 0%, #3d405b 100%);
  padding: 18px;
  border-radius: 14px;
  color: #fff;
  height: calc(100vh - 120px);
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
  position: fixed;
  top: 96px;
  left: max(24px, calc((100vw - 1200px) / 2 + 24px));
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  z-index: 20;
}

.sidebar.collapsed {
  align-items: stretch;
}

.sidebar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 18px;
  padding: 12px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.sidebar-header.collapsed {
  flex-direction: column;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand-badge {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #e07a5f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  letter-spacing: 0.5px;
  flex-shrink: 0;
}

.brand-title {
  font-weight: 800;
  font-size: 16px;
}

.brand-subtitle {
  font-size: 12px;
  opacity: 0.7;
  margin-top: 2px;
}

.sidebar-toggle {
  min-width: 40px;
  height: 40px;
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s ease, transform 0.2s ease;
}

.sidebar-toggle:hover {
  background: rgba(255, 255, 255, 0.2);
  transform: translateY(-1px);
}

.sidebar-nav {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
  overflow-y: auto;
  padding-right: 4px;
}

.sidebar-link {
  display: flex;
  align-items: center;
  padding: 10px 12px;
  border-radius: 8px;
  color: #fff;
  text-decoration: none;
  font-weight: 600;
  transition: background 0.2s ease, border-color 0.2s ease;
  cursor: pointer;
  border: 1px solid transparent;
}

.sidebar-link:hover {
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.12);
}

.sidebar-link.active {
  border-left: 4px solid #e07a5f;
  padding-left: 10px;
  background: rgba(224, 122, 95, 0.18);
}

.sidebar-section {
  margin-bottom: 4px;
}

.sidebar-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.2s ease;
  font-weight: 600;
  border: 1px solid transparent;
}

.sidebar-section-header:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.12);
}

.sidebar-section-title {
  flex: 1;
}

.sidebar-chevron {
  font-size: 14px;
  line-height: 1;
}

.sidebar-section-content {
  display: none;
  margin-top: 4px;
  padding-left: 8px;
}

.sidebar-section-content.expanded {
  display: block;
}

.sidebar-sublink {
  padding-left: 24px;
  font-size: 13px;
  font-weight: 600;
  opacity: 0.9;
}

@media (max-width: 900px) {
  :host,
  :host(.collapsed) {
    width: 100%;
    flex-basis: auto;
  }

  .sidebar {
    position: static;
    height: auto;
    left: auto;
    top: auto;
  }

  .sidebar-header,
  .sidebar-header.collapsed {
    flex-direction: row;
  }
}
