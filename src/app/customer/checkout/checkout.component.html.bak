<section class="checkout-page">
  <header class="checkout-header">
    <h1>Address And Payment</h1>
    <p>Confirm your shipping details and payment information before placing the order.</p>
  </header>

  <div class="checkout-grid">
    <section class="checkout-card">
      <div class="card-heading">
        <h2>Add Shipping Address</h2>
      </div>

      <form [formGroup]="addressForm" (ngSubmit)="submitOrder()" class="checkout-form">
        <div class="user-box">
          <label for="checkout-email">Email</label>
          <input id="checkout-email" formControlName="email" type="text" name="email" placeholder="Enter your email" />
        </div>

        <div class="user-box">
          <label for="checkout-address">Address</label>
          <textarea
            id="checkout-address"
            formControlName="address"
            name="address"
            cols="30"
            rows="4"
            placeholder="Enter your address"></textarea>
        </div>

        <div class="user-box">
          <label for="checkout-contact">Contact</label>
          <input id="checkout-contact" formControlName="contact" type="text" name="contact" placeholder="Enter your contact number" />
        </div>

        <button type="submit" class="primary-btn">Submit Order</button>
      </form>
    </section>

    <section class="checkout-card checkout-summary">
      <div class="card-heading">
        <h2>Payment Summary</h2>
      </div>

      <div class="pay-method">
        <h3>Total Amount</h3>
        <p class="total-price">₹ {{ totalPrice }}</p>
      </div>

      <app-payments [embedded]="true"></app-payments>
    </section>
  </div>

  <div class="order-msg" *ngIf="orderMsg">
    <h2>{{orderMsg}}</h2>
  </div>
</section>
