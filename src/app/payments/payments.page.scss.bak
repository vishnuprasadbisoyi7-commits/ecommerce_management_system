:host {
  display: block;
}

.payments {
  max-width: 520px;
  margin: 40px auto;
  background: #ffffff;
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 10px 28px rgba(47, 49, 70, 0.12);
}

.payments.embedded {
  max-width: 100%;
  margin: 24px 0 0;
  box-shadow: none;
  border: 1px solid #eee;
}

.payments-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
}

.payments-header h2 {
  margin: 0;
  color: #2f3146;
}

.home-link {
  text-decoration: none;
  font-weight: 600;
  color: #3d405b;
}

.payments-form {
  display: grid;
  gap: 12px;
}

.payments-form input {
  padding: 12px 14px;
  border-radius: 10px;
  border: 1px solid #d6d6d6;
  font-size: 14px;
}

.pay-btn {
  padding: 12px;
  border: none;
  border-radius: 10px;
  background: #2f3146;
  color: #fff;
  font-weight: 700;
  cursor: pointer;
}
